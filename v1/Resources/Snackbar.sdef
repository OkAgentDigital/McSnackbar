<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE dictionary SYSTEM "file://localhost/System/Library/DTDs/sdef.dtd">
<dictionary title="McSnackbar Dictionary">
    <suite name="McSnackbar Suite" code="SnBk" description="McSnackbar note management and automation">
        
        <!-- Note Object -->
        <class name="note" code="cNot" description="A note in Snackbar" plural="notes">
            <coclass name="text"/>
            <property name="id" code="pID " type="text" description="The unique identifier" access="r"/>
            <property name="title" code="pTtl" type="text" description="The note title" access="r"/>
            <property name="content" code="pCnt" type="text" description="The note content" access="r"/>
            <property name="tags" code="pTag" type="list of text" description="Note tags" access="r"/>
            <property name="created at" code="pCrt" type="date" description="Creation date" access="r"/>
            <property name="updated at" code="pUpd" type="date" description="Last update date" access="r"/>
            <property name="synced" code="pSyn" type="boolean" description="Whether the note is synced with iCloud" access="r"/>
        </class>
        
        <!-- Application Object -->
        <class name="application" code="capp" description="The Snackbar application">
            <responds-to command="create"/>
            <responds-to command="get"/>
            <responds-to command="update"/>
            <responds-to command="delete"/>
            <responds-to command="sync"/>
            <responds-to command="trigger skill"/>
            
            <element type="note" access="r">
                <coclass name="note"/>
            </element>
            
            <!-- Commands -->
            <command name="create note" code="SnBkCrNt" description="Create a new note">
                <direct-parameter type="note" description="The note to create"/>
                <parameter name="title" code="pTtl" type="text" description="The note title" optional="no"/>
                <parameter name="content" code="pCnt" type="text" description="The note content" optional="no"/>
                <parameter name="tags" code="pTag" type="list of text" description="Note tags" optional="yes"/>
                <result type="note" description="The created note"/>
            </command>
            
            <command name="get notes" code="SnBkGtNt" description="Get all notes">
                <result type="list of note" description="All notes in Snackbar"/>
            </command>
            
            <command name="update note" code="SnBkUpNt" description="Update a note">
                <direct-parameter type="note" description="The note to update"/>
                <parameter name="id" code="pID " type="text" description="The note ID" optional="no"/>
                <parameter name="new content" code="pCnt" type="text" description="The new content" optional="no"/>
                <result type="note" description="The updated note"/>
            </command>
            
            <command name="delete note" code="SnBkDlNt" description="Delete a note">
                <direct-parameter type="note" description="The note to delete"/>
                <parameter name="id" code="pID " type="text" description="The note ID" optional="no"/>
                <result type="text" description="Deletion status"/>
            </command>
            
            <command name="sync notes" code="SnBkSync" description="Sync notes with iCloud">
                <result type="text" description="Sync status"/>
            </command>
            
            <command name="get sync status" code="SnBkGtSt" description="Get sync status">
                <result type="record" description="Sync status information">
                    <property name="is online" code="pOnl" type="boolean" description="Whether the device is online"/>
                    <property name="iCloud available" code="pICld" type="boolean" description="Whether iCloud is available"/>
                    <property name="has pending changes" code="pPnd" type="boolean" description="Whether there are pending changes"/>
                </result>
            </command>
            
            <command name="trigger devstudio skill" code="SnBkTrSk" description="Trigger a DevStudio skill">
                <parameter name="skill name" code="pSkN" type="text" description="The skill name" optional="no"/>
                <parameter name="arguments" code="pArg" type="text" description="Skill arguments" optional="yes"/>
                <result type="text" description="Skill execution result"/>
            </command>
        </class>
        
        <!-- Enumerations -->
        <enumeration name="sync status" code="eSync">
            <enumerator name="online" code="eOnl" description="Device is online"/>
            <enumerator name="offline" code="eOfl" description="Device is offline"/>
            <enumerator name="iCloud available" code="eICld" description="iCloud is available"/>
            <enumerator name="iCloud unavailable" code="eNoIC" description="iCloud is unavailable"/>
        </enumeration>
        
    </suite>
</dictionary>