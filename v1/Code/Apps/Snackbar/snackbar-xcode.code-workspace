{
  "folders": [
    {
      "name": "Snackbar",
      "path": "."
    }
  ],
  "settings": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.renderWhitespace": "boundary",
    "editor.rulers": [80, 120],
    "files.exclude": {
      "**/.git": true,
      "**/.DS_Store": true,
      "**/build": true,
      "**/DerivedData": true,
      "**/Pods": true,
      "**/*.xcworkspace": true,
      "**/*.xcodeproj/xcuserdata": true,
      "**/*.xcodeproj/project.xcworkspace/xcuserdata": true
    },
    "files.associations": {
      "*.swift": "swift",
      "*.xib": "xml",
      "*.storyboard": "xml",
      "*.entitlements": "xml",
      "*.xcconfig": "properties"
    },
    "[swift]": {
      "editor.defaultFormatter": null,
      "editor.tabSize": 4,
      "editor.insertSpaces": true
    },
    "workbench.colorTheme": "Dark Modern",
    "workbench.iconTheme": null,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "git.enableCommitSigning": false,
    "git.autofetch": true,
    "swift.path": "/Applications/Xcode.app/Contents/Developer/Toolchains/XcodeDefault.xctoolchain/usr/bin"
  },
  "extensions": {
    "recommendations": [
      "swiftlang.swift-vscode",
      "vknabel.vscode-swift-development-environment",
      "adamhartford.vscode-swiftlint",
      "kasik96.swift-format",
      "cixtor.xcodekeybindings",
      "eamodio.gitlens",
      "aaron-bond.better-comments",
      "yzhang.markdown-all-in-one"
    ]
  }
}
