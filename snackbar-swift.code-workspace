{
  "folders": [
    {
      "name": "🍔 Snackbar",
      "path": "/Users/fredbook/Code/Apps/Snackbar"
    },
    {
      "name": "📁 Vault",
      "path": "/Users/fredbook/Vault"
    },
    {
      "name": "💻 DevStudio",
      "path": "/Users/fredbook/Code/DevStudio"
    }
  ],
  "settings": {
    "files.exclude": {
      "**/.build": true,
      "**/.derivedData": true,
      "**/node_modules": true,
      "**/target": true
    },
    "editor.formatOnSave": true,
    "editor.minimap.enabled": false,
    "workbench.colorTheme": "Dark Modern",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.startupEditor": "none",
    "extensions.ignoreRecommendations": true
  },
  "launch": {
    "configurations": [
      {
        "type": "swift",
        "request": "launch",
        "args": [],
        "cwd": "${workspaceFolder:🍔 Snackbar}",
        "name": "Debug Snackbar",
        "target": "Snackbar",
        "configuration": "debug",
        "preLaunchTask": "swift: Build Debug Snackbar"
      },
      {
        "type": "swift",
        "request": "launch",
        "args": [],
        "cwd": "${workspaceFolder:🍔 Snackbar}",
        "name": "Release Snackbar",
        "target": "Snackbar",
        "configuration": "release",
        "preLaunchTask": "swift: Build Release Snackbar"
      }
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "type": "shell",
        "label": "🍔 Build",
        "command": "cd ${workspaceFolder:🍔 Snackbar} && swift build",
        "group": "build",
        "presentation": { "reveal": "always", "panel": "new" }
      },
      {
        "type": "shell",
        "label": "🍔 Run",
        "command": "cd ${workspaceFolder:🍔 Snackbar} && swift run &",
        "group": "test",
        "presentation": { "reveal": "always", "panel": "new" }
      },
      {
        "type": "shell",
        "label": "🍔 Stop",
        "command": "pkill -f Snackbar 2>/dev/null; echo 'Stopped'",
        "group": "test"
      },
      {
        "type": "shell",
        "label": "🍔 Rebuild & Run",
        "command": "cd ${workspaceFolder:🍔 Snackbar} && swift build && swift run &",
        "group": "build"
      },
      {
        "type": "shell",
        "label": "🍔 Status",
        "command": "pgrep -f Snackbar | grep -v grep && echo 'Running' || echo 'Not running'",
        "group": "test"
      }
    ]
  }
}
