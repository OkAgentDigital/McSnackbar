# Snack: Gift Wrapper Surfaces
id: gift_wrapper_surfaces
name: Gift Wrapper Surfaces
description: Enable uDosGo USXD surface rendering and management
emoji: "🎁"
runtime: shell
categoryId: udos
isEnabled: true

code: |
  echo "Gift Wrapper Surfaces enabled"
  echo "Available surfaces:"
  ls -1 "$HOME/Code/uDosGo/surfaces/"*.md 2>/dev/null | sed 's/.*\///' | sed 's/\.md$//' || echo "No surfaces found"
