# Snack: DevStudio Surfaces
id: devstudio_surfaces
name: DevStudio Surfaces
description: Enable DevStudio surface configuration and management
emoji: "💻"
runtime: shell
categoryId: udos
isEnabled: true

code: |
  echo "DevStudio Surfaces enabled"
  echo "Available configs:"
  ls -1 "$HOME/Code/DevStudio/config/"* 2>/dev/null | sed 's/.*\///' || echo "No configs found"
