<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>XCService</key>
    <dict>
        <key>ServiceName</key>
        <string>com.udos.Snackbar.XCSBuildService</string>
        <key>ServiceType</key>
        <string>ExternalAgent</string>
        <key>ServiceDescription</key>
        <string>Snackbar Xcode Build Service — builds HivemindRust and other projects</string>
        <key>ServiceVersion</key>
        <string>1.0</string>
        
        <!-- Commands this agent can handle -->
        <key>Commands</key>
        <array>
            <dict>
                <key>CommandName</key>
                <string>buildProject</string>
                <key>CommandDescription</key>
                <string>Build a project by name</string>
                <key>Parameters</key>
                <array>
                    <dict>
                        <key>ParameterName</key>
                        <string>projectName</string>
                        <key>ParameterType</key>
                        <string>String</string>
                        <key>ParameterDescription</key>
                        <string>Name of the project to build (HivemindRust, Snackbar, Re3Engine)</string>
                    </dict>
                </array>
            </dict>
            <dict>
                <key>CommandName</key>
                <string>buildAll</string>
                <key>CommandDescription</key>
                <string>Build all known projects</string>
                <key>Parameters</key>
                <array/>
            </dict>
            <dict>
                <key>CommandName</key>
                <string>getStatus</string>
                <key>CommandDescription</key>
                <string>Get the current build status</string>
                <key>Parameters</key>
                <array/>
            </dict>
        </array>
        
        <!-- Notifications this agent can send -->
        <key>Notifications</key>
        <array>
            <dict>
                <key>NotificationName</key>
                <string>buildStarted</string>
                <key>NotificationDescription</key>
                <string>Sent when a build starts</string>
            </dict>
            <dict>
                <key>NotificationName</key>
                <string>buildCompleted</string>
                <key>NotificationDescription</key>
                <string>Sent when a build completes (success or failure)</string>
            </dict>
        </array>
    </dict>
</dict>
</plist>
